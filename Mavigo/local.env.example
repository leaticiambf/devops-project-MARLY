APP_FRONTEND_BASE_URL=http://localhost:3000
APP_FRONTEND_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# Register this exact redirect URI in Google Cloud OAuth:
# http://localhost:3000/login/oauth2/code/google

DB_URL=jdbc:h2:file:./data/mavigo;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH
DB_USERNAME=sa
DB_PASSWORD=

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=86400000

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

PRIM_API_KEY=replace-with-prim-api-key

# Optional local-only helpers
# APP_H2_CONSOLE_ENABLED=true
# LOG_LEVEL_SPRING_SECURITY=DEBUG
# LOG_LEVEL_WEBCLIENT=DEBUG
# LOG_LEVEL_REACTOR_NETTY=DEBUG
