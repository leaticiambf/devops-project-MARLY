APP_FRONTEND_BASE_URL=http://localhost:3000
APP_FRONTEND_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# Copy this file to local.env for local development.
# Do not commit local.env or real production secrets.
# Local Google OAuth redirect URI:
# http://localhost:3000/login/oauth2/code/google

# Local H2 option.
DB_URL=jdbc:h2:file:./data/mavigo;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH;AUTO_SERVER=TRUE
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER_CLASS_NAME=org.h2.Driver
JPA_HIBERNATE_DIALECT=org.hibernate.dialect.H2Dialect

# Aiven PostgreSQL / hosted deployment option.
# Set these values in the hosting provider environment, not in Git.
# DB_URL=jdbc:postgresql://HOST:PORT/defaultdb?sslmode=require
# DB_USERNAME=avnadmin
# DB_PASSWORD=replace-with-aiven-password
# DB_DRIVER_CLASS_NAME=org.postgresql.Driver
# JPA_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
# JPA_DDL_AUTO=update

# Hosting platforms usually inject PORT automatically.
# PORT=8080

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=86400000

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

PRIM_API_KEY=replace-with-prim-api-key
TOURISM_YELP_API_KEY=

# Local-only helpers.
# APP_H2_CONSOLE_ENABLED=true

# LOG_LEVEL_SPRING_SECURITY=DEBUG
# LOG_LEVEL_WEBCLIENT=DEBUG
# LOG_LEVEL_REACTOR_NETTY=DEBUG
